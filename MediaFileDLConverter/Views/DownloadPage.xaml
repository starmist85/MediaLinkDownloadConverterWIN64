<UserControl x:Class="MediaFileDLConverter.Views.DownloadPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- URL Input Section -->
        <Border Grid.Row="0" Background="#1E1E2E" CornerRadius="12" Margin="20,15,20,8" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- URL TextBox -->
                <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="8" Padding="2">
                    <TextBox x:Name="UrlTextBox"
                             Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             VerticalAlignment="Center"
                             FontSize="14"
                             Padding="14,10"
                             Tag="Paste a YouTube, SoundCloud, or MixCloud link..."/>
                </Border>

                <!-- Download Button -->
                <Button Grid.Column="1"
                        Content="Download"
                        Command="{Binding DownloadCommand}"
                        Style="{StaticResource AccentButton}"
                        Margin="12,0,0,0"
                        Padding="28,10"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Height="42"/>

                <!-- Platform badge -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="4,8,0,0"
                            Visibility="{Binding IsLinkValid, Converter={StaticResource BoolToVisibility}}">
                    <Border Background="#3A3A5E" CornerRadius="4" Padding="10,4">
                        <TextBlock Text="{Binding LinkTypeDisplay}" Foreground="#BB86FC" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#3A3A5E" CornerRadius="4" Padding="10,4" Margin="6,0,0,0"
                            Visibility="{Binding HasPlaylist, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Playlist Detected" Foreground="#03DAC6" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Download Mode Selection -->
        <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="12" Margin="20,0,20,8" Padding="20,14">
            <StackPanel>
                <TextBlock Text="D O W N L O A D   M O D E" Foreground="#8888AA" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Download Single"
                                 IsChecked="{Binding IsSingleMode}"
                                 Style="{StaticResource ModernRadioButton}"
                                 Margin="0,0,24,0"/>
                    <RadioButton Content="Download Playlist / Set"
                                 IsChecked="{Binding IsPlaylistMode}"
                                 Style="{StaticResource ModernRadioButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Format Selection -->
        <Border Grid.Row="2" Background="#1E1E2E" CornerRadius="12" Margin="20,0,20,8" Padding="20,14">
            <StackPanel>
                <TextBlock Text="O U T P U T   F O R M A T" Foreground="#8888AA" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <WrapPanel>
                    <RadioButton Content="🎵 MP3 (320kbps)"
                                 IsChecked="{Binding IsFormatMp3}"
                                 IsEnabled="{Binding IsMp3Enabled}"
                                 GroupName="Format"
                                 Style="{StaticResource FormatRadioButton}"
                                 Margin="0,0,12,8"/>
                    <RadioButton Content="🎶 WAV (Lossless)"
                                 IsChecked="{Binding IsFormatWav}"
                                 IsEnabled="{Binding IsWavEnabled}"
                                 GroupName="Format"
                                 Style="{StaticResource FormatRadioButton}"
                                 Margin="0,0,12,8"/>
                    <RadioButton Content="🎬 MP4 (720p)"
                                 IsChecked="{Binding IsFormatMp4Low}"
                                 IsEnabled="{Binding IsMp4LowEnabled}"
                                 GroupName="Format"
                                 Style="{StaticResource FormatRadioButton}"
                                 Margin="0,0,12,8"/>
                    <RadioButton Content="🎬 MP4 (Best Quality)"
                                 IsChecked="{Binding IsFormatMp4High}"
                                 IsEnabled="{Binding IsMp4HighEnabled}"
                                 GroupName="Format"
                                 Style="{StaticResource FormatRadioButton}"
                                 Margin="0,0,12,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Download Queue -->
        <Border Grid.Row="3" Background="#1E1E2E" CornerRadius="12" Margin="20,0,20,12" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#252540" CornerRadius="12,12,0,0" Padding="20,12">
                    <Grid>
                        <TextBlock Text="D O W N L O A D   Q U E U E" Foreground="#8888AA" FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel All"
                                    Command="{Binding CancelAllCommand}"
                                    Style="{StaticResource LinkButton}"
                                    Foreground="#FF6666"
                                    FontSize="11"
                                    Margin="0,0,14,0"/>
                            <Button Content="Clear Completed"
                                    Command="{Binding ClearCompletedCommand}"
                                    Style="{StaticResource LinkButton}"
                                    FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Queue Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding DownloadQueue}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#22223A" CornerRadius="8" Margin="12,6" Padding="16,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Title -->
                                        <TextBlock Grid.Column="0" Grid.Row="0"
                                                   Text="{Binding Title}"
                                                   Foreground="#E0E0F0"
                                                   FontSize="13" FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,12,2"/>

                                        <!-- Format Badge -->
                                        <Border Grid.Column="1" Grid.Row="0"
                                                Background="#3A3A5E" CornerRadius="4" Padding="8,3"
                                                VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding FormatLabel}"
                                                       Foreground="#BB86FC" FontSize="10" FontWeight="Bold"/>
                                        </Border>

                                        <!-- Status -->
                                        <TextBlock Grid.Column="2" Grid.Row="0"
                                                   Text="{Binding StatusText}"
                                                   Foreground="{Binding StatusColor}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>

                                        <!-- Cancel Button -->
                                        <Button Grid.Column="3" Grid.Row="0"
                                                Content="✕"
                                                Command="{Binding CancelCommand}"
                                                Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibility}}"
                                                Style="{StaticResource CancelButton}"
                                                VerticalAlignment="Center"/>

                                        <!-- Progress Bar -->
                                        <Grid Grid.Row="1" Grid.ColumnSpan="4" Margin="0,6,0,0"
                                              Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                                            <Border Background="#1A1A2E" CornerRadius="3" Height="6"/>
                                            <Border CornerRadius="3" Height="6"
                                                    HorizontalAlignment="Left">
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource ProgressWidthConverter}">
                                                        <Binding Path="Progress"/>
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#BB86FC" Offset="0"/>
                                                        <GradientStop Color="#03DAC6" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty State -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding DownloadQueue.Count, Converter={StaticResource ZeroToVisibility}}">
                    <TextBlock Text="📥" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="No downloads yet" Foreground="#555570" FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Paste a link above to get started" Foreground="#444460" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
