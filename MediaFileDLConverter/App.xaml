<Application x:Class="MediaFileDLConverter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediaFileDLConverter.Helpers"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- CONVERTERS -->
            <!-- ═══════════════════════════════════════════════════ -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <helpers:ZeroToVisibilityConverter x:Key="ZeroToVisibility"/>
            <helpers:ProgressWidthConverter x:Key="ProgressWidthConverter"/>
            <helpers:BoolToFontWeightConverter x:Key="BoolToFontWeight"/>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- FONTS -->
            <!-- ═══════════════════════════════════════════════════ -->
            <FontFamily x:Key="AppFont">Segoe UI, Inter, Arial</FontFamily>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- COLOR PALETTE -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Color x:Key="BgDark">#141422</Color>
            <Color x:Key="BgCard">#1E1E2E</Color>
            <Color x:Key="BgInput">#2A2A3E</Color>
            <Color x:Key="BgHover">#3A3A55</Color>
            <Color x:Key="AccentPurple">#BB86FC</Color>
            <Color x:Key="AccentTeal">#03DAC6</Color>
            <Color x:Key="ErrorRed">#FF4444</Color>
            <Color x:Key="SuccessGreen">#66BB6A</Color>
            <Color x:Key="TextPrimary">#E0E0F0</Color>
            <Color x:Key="TextSecondary">#8888AA</Color>
            <Color x:Key="TextMuted">#555570</Color>

            <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
            <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
            <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInput}"/>
            <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}"/>
            <SolidColorBrush x:Key="AccentTealBrush" Color="{StaticResource AccentTeal}"/>
            <SolidColorBrush x:Key="ErrorRedBrush" Color="{StaticResource ErrorRed}"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- MODERN TEXTBOX STYLE -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Style x:Key="ModernTextBox" TargetType="TextBox">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="CaretBrush" Value="{StaticResource AccentPurpleBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="SelectionBrush" Value="{StaticResource AccentPurpleBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="Center"/>
                                <TextBlock x:Name="Placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#555570"
                                           FontFamily="{StaticResource AppFont}"
                                           Padding="{TemplateBinding Padding}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="Text" Value="{x:Null}">
                                    <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ACCENT BUTTON (Primary action) -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Style x:Key="AccentButton" TargetType="Button">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#BB86FC" Offset="0"/>
                            <GradientStop Color="#9C5CFC" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#CC99FF" Offset="0"/>
                                                <GradientStop Color="#AA77FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#9966DD" Offset="0"/>
                                                <GradientStop Color="#7744CC" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- SECONDARY BUTTON -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="Background" Value="#2A2A3E"/>
                <Setter Property="Foreground" Value="#CCCCDD"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#3A3A55"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#3A3A55"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#5A5A75"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#252540"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ICON BUTTON (for settings gear etc.) -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2A2A40"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#3A3A55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- LINK BUTTON (text-style) -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Style x:Key="LinkButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#BB86FC"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="text"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Padding="{TemplateBinding Padding}"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="text" Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- CANCEL BUTTON (X) -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Style x:Key="CancelButton" TargetType="Button">
                <Setter Property="Background" Value="#3A2020"/>
                <Setter Property="Foreground" Value="#FF6666"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Width" Value="28"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="14"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#552222"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#661111"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- MODERN RADIO BUTTON -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Style x:Key="ModernRadioButton" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="radioOuter"
                                        Width="18" Height="18"
                                        CornerRadius="9"
                                        BorderBrush="#555570"
                                        BorderThickness="2"
                                        Background="Transparent"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <Ellipse x:Name="radioInner"
                                             Width="8" Height="8"
                                             Fill="{StaticResource AccentPurpleBrush}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="radioInner" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="radioOuter" Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="radioOuter" Property="BorderBrush" Value="#7777AA"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- FORMAT RADIO BUTTON (pill-style) -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Style x:Key="FormatRadioButton" TargetType="RadioButton">
                <Setter Property="Foreground" Value="#CCCCDD"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="pill"
                                    Background="#252540"
                                    CornerRadius="8"
                                    Padding="16,10"
                                    BorderBrush="#3A3A55"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="pill" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#2D1B5E" Offset="0"/>
                                                <GradientStop Color="#1E2D4E" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="pill" Property="BorderBrush" Value="#BB86FC"/>
                                    <Setter Property="Foreground" Value="#BB86FC"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="pill" Property="BorderBrush" Value="#6666AA"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="pill" Property="Opacity" Value="0.3"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- MODERN TAB CONTROL -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Style x:Key="ModernTabControl" TargetType="TabControl">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Tab Header Strip -->
                                <Border Grid.Row="0" Background="#181830" Padding="16,0">
                                    <TabPanel IsItemsHost="True" Margin="0"/>
                                </Border>

                                <!-- Tab Content -->
                                <Border Grid.Row="1" Background="{StaticResource BgDarkBrush}">
                                    <ContentPresenter ContentSource="SelectedContent"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- MODERN TAB ITEM -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Style x:Key="ModernTabItem" TargetType="TabItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#666680"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Padding" Value="20,12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Grid>
                                <Border x:Name="tabBorder"
                                        Background="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter x:Name="contentPresenter"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="indicator"
                                        Height="3" VerticalAlignment="Bottom"
                                        CornerRadius="1.5"
                                        Visibility="Collapsed">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#BB86FC" Offset="0"/>
                                            <GradientStop Color="#03DAC6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="#E0E0F0"/>
                                    <Setter TargetName="indicator" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#AAAACC"/>
                                    <Setter TargetName="tabBorder" Property="Background" Value="#1E1E35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- SCROLLBAR STYLING -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Style TargetType="ScrollViewer">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollViewer">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ScrollContentPresenter Grid.Column="0"/>
                                <ScrollBar Grid.Column="1"
                                           Value="{TemplateBinding VerticalOffset}"
                                           Maximum="{TemplateBinding ScrollableHeight}"
                                           ViewportSize="{TemplateBinding ViewportHeight}"
                                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                           Width="6"
                                           Margin="2,0,2,0"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
